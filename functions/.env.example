# Firebase Functions region
FUNCTION_REGION=europe-west1

# Optional explicit Firebase project id
FIREBASE_PROJECT_ID=

# Gemini Developer API key used by the managed backend
GEMINI_API_KEY=

# Android package id used for Google Play purchase verification
GOOGLE_PLAY_PACKAGE_NAME=com.ronitervo.maestrotutor

# Browser/webview origins allowed to call the backend
ALLOWED_ORIGINS=https://chatwithmaestro.com,https://chatwithmaestro.web.app,https://localhost,http://localhost,capacitor://localhost

# Product grants in productId:credits format
MANAGED_CREDIT_PRODUCTS=maestro_credits_1000:1000

# Credit conversion: 1000 means 1 USD of Gemini cost becomes 1000 billed credits
MANAGED_CREDITS_PER_USD=1000

# Keep false unless web App Check is enabled. Native localhost requests stay exempt.
REQUIRE_APPCHECK=false

# Single-use live/audio tokens by default
GEMINI_LIVE_TOKEN_USES=1

# Reservation expiry and fixed live/music token charges
RESERVATION_TTL_MINUTES=30
MANAGED_LIVE_SESSION_CREDITS=40
MANAGED_MUSIC_SESSION_CREDITS=120
